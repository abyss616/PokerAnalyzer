@page "/handhistories/upload"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components.Web
@using PokerAnalyzer.Web.Models
@inject PokerAnalyzer.Web.Services.ApiClient Api
@inject TooltipService TooltipService
<h3>Upload Hand History (XML)</h3>

<p>Select an XML hand history file. Upload starts immediately.</p>

<InputFile OnChange="OnFileSelected" accept=".xml" />

@if (!string.IsNullOrWhiteSpace(_status))
{
    <div class="alert alert-info mt-3">
        @_status
    </div>
}

@if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger mt-3">
        <pre style="white-space:pre-wrap">@_error</pre>
    </div>
}

@if (_sessionId != Guid.Empty)
{
    <div class="card mt-4">
        <div class="card-title">Run solver for a hand</div>
        <p class="text-muted mb-2">Enter a hand number from the uploaded session (example: 18).</p>

        <div class="form-group">
            <label class="form-label" for="hand-number-input">Hand number</label>
            <InputNumber id="hand-number-input"
                         class="form-control"
                         @bind-Value="_handNumber"
                         min="1" />
        </div>
        <button class="btn btn-primary mt-2"
                disabled="@(!_handNumber.HasValue)"
                @onclick="RunSolverAsync">
            Run solver
        </button>
        <button class="btn btn-secondary mt-2 ms-2"
                disabled="@(!_handNumber.HasValue)"
                @onclick="RunAnalysisAsync">
            Run Analysis
        </button>

        @if (_analysisSteps.Count > 0)
        {
            <div class="mt-3">
                <h5>Analysis Steps</h5>
                <table class="table table-sm">
                    <thead>
                    <tr>
                        <th>Time</th>
                        <th>Title</th>
                        <th>Details</th>
                        <th>Status</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var step in _analysisSteps)
                    {
                        <tr>
                            <td>@step.Time.ToString("HH:mm:ss")</td>
                            <td>@step.Title</td>
                            <td>@step.Details</td>
                            <td>@step.Status</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(_solverStatus))
        {
            <div class="alert alert-success mt-3">
                @_solverStatus
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(_solverError))
        {
            <div class="alert alert-danger mt-3">
                <pre style="white-space:pre-wrap">@_solverError</pre>
            </div>
        }

        @if (_solverResult is not null)
        {
            <div class="card mt-3 p-3">
                <h5 class="mb-2">Preflop Actions</h5>
                <table class="table table-sm table-striped mb-0">
                    <thead>
                    <tr>
                        <th>Seat</th>
                        <th>Player Name</th>
                        <th>Position</th>
                        <th>Stack at Start</th>
                        <th>Actions</th>
                        <th>Total Put In</th>
                        <th>In Hand?</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var player in _solverResult.PreflopSummary.Players.OrderBy(p => p.Seat))
                    {
                        var actionSequence = player.Actions.Count == 0
                            ? "—"
                            : string.Join(" → ", player.Actions.OrderBy(a => a.Order).Select(a => a.Display));

                        <tr>
                            <td>@player.Seat</td>
                            <td>@(player.Name ?? "—")</td>
                            <td>@(player.Position ?? "—")</td>
                            <td>@(player.StartingStack.HasValue ? $"€{player.StartingStack.Value:0.00}" : "—")</td>
                            <td>@actionSequence</td>
                            <td>@($"€{player.TotalPutIn:0.00}")</td>
                            <td>@(player.Occupied ? (player.FoldedPreflop ? "No" : "Yes") : "—")</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>

            <div class="mt-3">
                @foreach (var engine in _solverResult.Engines)
                {
                    <div class="card mt-2 p-3">
                        <h5 class="mb-2">@engine.Engine engine</h5>
                        <p class="text-muted mb-2">Decisions reviewed: @engine.DecisionCount</p>

                        @if (engine.Decisions.Count == 0)
                        {
                            <div class="text-muted">No hero decisions were found for this hand.</div>
                        }
                        else
                        {
                            <table class="table table-sm table-striped">
                                <thead>
                                <tr>
                                    <th>Street</th>
                                    <th>Hero Cards</th>
                                    <th>Hero Position</th>
                                    <th>Villain Position</th>
                                    <th>Villain Action</th>
                                    <th>Hero Action</th>
                                    <th>Solver Recommendation</th>
                                    <th>Solver EV</th>
                                    <th>Monte Carlo Reference EV</th>
                                </tr>
                                </thead>
                                <tbody>
                                @foreach (var decision in engine.Decisions)
                                {
                                    var invalidPositionMapping = !string.IsNullOrWhiteSpace(decision.HeroPosition)
                                        && !string.IsNullOrWhiteSpace(decision.VillainPosition)
                                        && string.Equals(decision.HeroPosition, decision.VillainPosition, StringComparison.OrdinalIgnoreCase);

                                    <tr>
                                        <td>@decision.Street</td>
                                        <td>@(decision.HeroCards ?? "Unknown")</td>
                                        <td>@(decision.HeroPosition ?? "Unknown")</td>
                                        <td>@(decision.VillainPosition ?? "Unknown")</td>
                                        <td>@(invalidPositionMapping ? "Invalid Position Mapping" : decision.VillainAction ?? "N/A")</td>
                                        <td>@decision.HeroAction</td>
                                        <td>@(invalidPositionMapping ? "Invalid Position Mapping" : decision.RecommendedAction)</td>
                                        <td>@(invalidPositionMapping ? "Invalid Position Mapping" : decision.PrimaryEv?.ToString("0.###") ?? "N/A")</td>
                                        <td>@(invalidPositionMapping ? "Invalid Position Mapping" : decision.ReferenceEv?.ToString("0.###") ?? "N/A")</td>
                                    </tr>
                                    @if (!invalidPositionMapping && !string.IsNullOrWhiteSpace(decision.PrimaryExplanation))
                                    {
                                        <tr>
                                            <td colspan="9" class="text-muted small"><strong>Solver:</strong> @decision.PrimaryExplanation</td>
                                        </tr>
                                    }
                                    @if (!invalidPositionMapping && !string.IsNullOrWhiteSpace(decision.ReferenceExplanation))
                                    {
                                        <tr>
                                            <td colspan="9" class="text-muted small"><strong>Monte Carlo Reference (non-decision):</strong> @decision.ReferenceExplanation</td>
                                        </tr>
                                    }
                                }
                                </tbody>
                            </table>
                        }
                    </div>
                }
            </div>
        }
    </div>
}

@if (_playerStats.Count > 0)
{
    <div class="mt-4">
        <h4>Player Stats</h4>

        <div class="grid-wrap">
            <RadzenDataGrid Data="@_playerStats"
                            TItem="PokerStatsGridModel"
                            AllowSorting="true"
                            AllowPaging="true"
                            PageSize="10"
                            AllowFiltering="true"
                            FilterMode="FilterMode.Simple"
                            AllowColumnResize="true"
                            ColumnResizeMode="DataGridColumnResizeMode.NextColumn"
                            AllowColumnReorder="true"
                            AllowColumnPicking="true"
                            Style="width: 100%;"
                            Class="player-stats-grid">

                <Columns>
                    <!-- Freeze these so you always see who/what row you're on -->
                    <RadzenDataGridColumn TItem="PokerStatsGridModel"
                                          Property="Player"
                                          Title="Player"
                                          Frozen="true"
                                          Width="220px" />

                    <RadzenDataGridColumn TItem="PokerStatsGridModel"
                                          Property="Hands"
                                          Title="Hands"
                                          Frozen="true"
                                          Width="100px"
                                          TextAlign="TextAlign.Right" />

                    @foreach (var statColumn in StatColumns)
                    {
                        <RadzenDataGridColumn TItem="PokerStatsGridModel"
                                              Property="@statColumn.Property"
                                              Title="@statColumn.Title"
                                              Width="100px"
                                              TextAlign="TextAlign.Right"
                                              Filterable="false"
                                              FormatString="{0:0.##}%">
                        </RadzenDataGridColumn>
                    }
                </Columns>
            </RadzenDataGrid>
        </div>
    </div>
}

@code {
    private string? _status;
    private string? _error;
    private string? _solverStatus;
    private string? _solverError;
    private ApiClient.HandSolverResponse? _solverResult;
    private Guid _sessionId;
    private int? _handNumber;
    private IReadOnlyList<PokerStatsGridModel> _playerStats = Array.Empty<PokerStatsGridModel>();
    private readonly List<StepLog> _analysisSteps = new();
    private static readonly IReadOnlyList<StatColumn> StatColumns = new[]
    {
        new StatColumn("VPIP", nameof(PokerStatsGridModel.VPIP)),
        new StatColumn("PFR", nameof(PokerStatsGridModel.PFR)),
        new StatColumn("3Bet", nameof(PokerStatsGridModel.ThreeBet)),
        new StatColumn("Faced 3Bet", nameof(PokerStatsGridModel.Faced3Bet)),
        new StatColumn("Fold to 3Bet", nameof(PokerStatsGridModel.FoldTo3Bet)),
        new StatColumn("Flop WTSD", nameof(PokerStatsGridModel.FlopWTSD)),
        new StatColumn("Flop W$SD", nameof(PokerStatsGridModel.FlopWSD)),
        new StatColumn("Flop CBet Opp", nameof(PokerStatsGridModel.FlopCBetOpp)),
        new StatColumn("Flop CBet", nameof(PokerStatsGridModel.FlopCBet)),
        new StatColumn("Fold to Flop CBet Opp", nameof(PokerStatsGridModel.FoldToFlopCBetOpp)),
        new StatColumn("Fold to Flop CBet", nameof(PokerStatsGridModel.FoldToFlopCBet)),
        new StatColumn("First Fold to CBet", nameof(PokerStatsGridModel.FirstFoldToCBet)),
        new StatColumn("Call vs CBet", nameof(PokerStatsGridModel.CallVsCBet)),
        new StatColumn("Raise vs CBet", nameof(PokerStatsGridModel.RaiseVsCBet)),
        new StatColumn("Multiway CBet", nameof(PokerStatsGridModel.MultiwayCBet)),
        new StatColumn("Turn WTSD", nameof(PokerStatsGridModel.TurnWTSD)),
        new StatColumn("Turn W$SD", nameof(PokerStatsGridModel.TurnWSD)),
        new StatColumn("Turn CBet", nameof(PokerStatsGridModel.TurnCBet)),
        new StatColumn("Turn Fold to Bet", nameof(PokerStatsGridModel.TurnFoldToBet)),
        new StatColumn("Turn Aggression", nameof(PokerStatsGridModel.TurnAggression)),
        new StatColumn("Turn WTSD Carryover", nameof(PokerStatsGridModel.TurnWTSDCarryover)),
        new StatColumn("River WTSD", nameof(PokerStatsGridModel.RiverWTSD)),
        new StatColumn("River W$SD", nameof(PokerStatsGridModel.RiverWSD)),
        new StatColumn("River Bets When Checked To", nameof(PokerStatsGridModel.RiverBetsWhenCheckedTo)),
        new StatColumn("River Fold to Bet", nameof(PokerStatsGridModel.RiverFoldToBet)),
        new StatColumn("River Aggression", nameof(PokerStatsGridModel.RiverAggression))
    };
    private static readonly IReadOnlyDictionary<string, string> StatDescriptions = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
    {
        ["VPIP"] = "Voluntarily Put Money In Pot: % of hands where the player called or raised preflop.",
        ["PFR"] = "Preflop Raise: % of hands where the player raised preflop.",
        ["3Bet"] = "Three-bet: % of hands where the player re-raised preflop.",
        ["Faced 3Bet"] = "Faced a three-bet: % of hands where the player opened and faced a re-raise.",
        ["Fold to 3Bet"] = "Folded to a three-bet after opening preflop.",
        ["Flop WTSD"] = "Flop Went To Showdown: % of hands reaching showdown after seeing the flop.",
        ["Flop W$SD"] = "Flop Won at Showdown: % of showdowns won after seeing the flop.",
        ["Flop CBet Opp"] = "Flop continuation bet opportunities: % of hands where the preflop aggressor could c-bet on the flop.",
        ["Flop CBet"] = "Flop continuation bet: % of opportunities where the player c-bet the flop.",
        ["Fold to Flop CBet Opp"] = "Flop fold-to-c-bet opportunities: % of hands where the player faced a flop c-bet.",
        ["Fold to Flop CBet"] = "Flop fold to c-bet: % of times the player folded when facing a flop c-bet.",
        ["First Fold to CBet"] = "First fold to flop c-bet: % of hands where the player was the first to fold versus a flop c-bet.",
        ["Call vs CBet"] = "Call vs flop c-bet: % of times the player called when facing a flop c-bet.",
        ["Raise vs CBet"] = "Raise vs flop c-bet: % of times the player raised when facing a flop c-bet.",
        ["Multiway CBet"] = "Multiway c-bet: % of times the player c-bet the flop in a multiway pot.",
        ["Turn WTSD"] = "Turn Went To Showdown: % of hands reaching showdown after seeing the turn.",
        ["Turn W$SD"] = "Turn Won at Showdown: % of showdowns won after seeing the turn.",
        ["Turn CBet"] = "Turn continuation bet: % of times the player fired a second barrel on the turn.",
        ["Turn Fold to Bet"] = "Turn fold to bet: % of times the player folded when facing a turn bet.",
        ["Turn Aggression"] = "Turn aggression factor: bets and raises divided by calls on the turn.",
        ["Turn WTSD Carryover"] = "Turn WTSD carryover: % of hands that reached showdown after seeing the turn.",
        ["River WTSD"] = "River Went To Showdown: % of hands reaching showdown after seeing the river.",
        ["River W$SD"] = "River Won at Showdown: % of showdowns won after seeing the river.",
        ["River Bets When Checked To"] = "River bet when checked to: % of times the player bet the river after it checked to them.",
        ["River Fold to Bet"] = "River fold to bet: % of times the player folded when facing a river bet.",
        ["River Aggression"] = "River aggression factor: bets and raises divided by calls on the river."
    };

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        _status = "OnFileSelected fired.";
        _status = null;
        _error = null;
        _solverStatus = null;
        _solverError = null;
        _solverResult = null;
        _handNumber = null;
        _sessionId = Guid.Empty;
        _playerStats = Array.Empty<PokerStatsGridModel>();

        try
        {
            var file = e.File;
            if (file is null)
            {
                _error = "No file received from InputFile.";
                return;
            }

            _status = $"Selected: {file.Name} ({file.Size} bytes). Uploading...";

            var result = await Api.UploadHandHistoryXmlAsync(file);

            _status = $"Upload successful. SessionId: {result.SessionId}";
            _sessionId = result.SessionId;

            var stats = await Api.GetPlayerStatsAsync(result.SessionId);
            _playerStats = stats.Select(MapToGridModel).ToList();
        }
        catch (Exception ex)
        {
            _error = ex.ToString();
        }
    }

    private async Task RunSolverAsync()
    {
        _solverStatus = null;
        _solverError = null;
        _solverResult = null;

        if (_sessionId == Guid.Empty)
        {
            _solverError = "Upload a hand history before running the solver.";
            return;
        }

        if (!_handNumber.HasValue || _handNumber <= 0)
        {
            _solverError = "Enter a valid hand number.";
            return;
        }

        try
        {
            var result = await Api.RunSolverAsync(_sessionId, _handNumber.Value);
            _solverResult = result;
            _solverStatus = $"Solver complete for hand #{result.HandNumber}. HandId: {result.HandId}.";
        }
        catch (Exception ex)
        {
            _solverError = ex.ToString();
        }
    }

    private async Task RunAnalysisAsync()
    {
        _analysisSteps.Clear();
        _solverStatus = null;
        _solverError = null;
        _solverResult = null;
        await AddStepAsync("Validation", "Validating analysis inputs.", "Running");

        if (_sessionId == Guid.Empty)
        {
            await AddStepAsync("Validation", "Upload a hand history before running analysis.", "Fail");
            _solverError = "Upload a hand history before running the solver.";
            return;
        }

        if (!_handNumber.HasValue || _handNumber <= 0)
        {
            await AddStepAsync("Validation", "Hand number is invalid.", "Fail");
            _solverError = "Enter a valid hand number.";
            return;
        }

        await AddStepAsync("Validation", "Inputs validated.", "OK");

        try
        {
            await AddStepAsync("Solver", $"Running solver for hand #{_handNumber.Value}.", "Running");
            var result = await Api.RunSolverAsync(_sessionId, _handNumber.Value);
            _solverResult = result;
            await AddStepAsync("Solver", $"Solver completed. HandId: {result.HandId}.", "OK");

            await AddStepAsync("Finalize", "Analysis complete.", "OK");
            _solverStatus = $"Solver complete for hand #{result.HandNumber}. HandId: {result.HandId}.";
        }
        catch (Exception ex)
        {
            _solverError = ex.ToString();
            await AddStepAsync("Solver", ex.Message, "Fail");
        }
    }

    private async Task AddStepAsync(string title, string details, string status)
    {
        _analysisSteps.Add(new StepLog
        {
            Time = DateTime.Now,
            Title = title,
            Details = details,
            Status = status
        });

        await InvokeAsync(StateHasChanged);
    }

    private static string GetStatDescription(string statName) =>
        StatDescriptions.TryGetValue(statName, out var description)
            ? description
            : "No description available.";

    private static PokerStatsGridModel MapToGridModel(PokerAnalyzer.Web.Services.ApiClient.PlayerStatsResult player)
    {
        var stats = player.Stats.ToDictionary(stat => stat.Name, StringComparer.OrdinalIgnoreCase);
        decimal? GetValue(string name) =>
            stats.TryGetValue(name, out var stat) ? stat.Percent : null;

        return new PokerStatsGridModel
        {
            Player = player.Player,
            Hands = player.Hands,
            VPIP = GetValue("VPIP"),
            PFR = GetValue("PFR"),
            ThreeBet = GetValue("3Bet"),
            Faced3Bet = GetValue("Faced 3Bet"),
            FoldTo3Bet = GetValue("Fold to 3Bet"),
            FlopWTSD = GetValue("Flop WTSD"),
            FlopWSD = GetValue("Flop W$SD"),
            FlopCBetOpp = GetValue("Flop CBet Opp"),
            FlopCBet = GetValue("Flop CBet"),
            FoldToFlopCBetOpp = GetValue("Fold to Flop CBet Opp"),
            FoldToFlopCBet = GetValue("Fold to Flop CBet"),
            FirstFoldToCBet = GetValue("First Fold to CBet"),
            CallVsCBet = GetValue("Call vs CBet"),
            RaiseVsCBet = GetValue("Raise vs CBet"),
            MultiwayCBet = GetValue("Multiway CBet"),
            TurnWTSD = GetValue("Turn WTSD"),
            TurnWSD = GetValue("Turn W$SD"),
            TurnCBet = GetValue("Turn CBet"),
            TurnFoldToBet = GetValue("Turn Fold to Bet"),
            TurnAggression = GetValue("Turn Aggression"),
            TurnWTSDCarryover = GetValue("Turn WTSD Carryover"),
            RiverWTSD = GetValue("River WTSD"),
            RiverWSD = GetValue("River W$SD"),
            RiverBetsWhenCheckedTo = GetValue("River Bets When Checked To"),
            RiverFoldToBet = GetValue("River Fold to Bet"),
            RiverAggression = GetValue("River Aggression")
        };
    }

    private sealed record StatColumn(string Title, string Property);
}

<style>
    .stat-tooltip {
        position: relative;
        cursor: help;
        border-bottom: 1px dotted rgba(0, 0, 0, 0.35);
    }

    .stat-tooltip::after {
        content: attr(data-tooltip);
        position: absolute;
        left: 0;
        top: 125%;
        z-index: 10;
        min-width: 220px;
        max-width: 320px;
        padding: 0.35rem 0.5rem;
        border-radius: 0.35rem;
        background: rgba(33, 37, 41, 0.95);
        color: #fff;
        font-size: 0.75rem;
        line-height: 1.2;
        opacity: 0;
        pointer-events: none;
        transform: translateY(-4px);
        transition: opacity 0.15s ease, transform 0.15s ease;
        white-space: normal;
    }

    .stat-tooltip::before {
        content: "";
        position: absolute;
        left: 12px;
        top: 115%;
        border-width: 6px;
        border-style: solid;
        border-color: transparent transparent rgba(33, 37, 41, 0.95) transparent;
        opacity: 0;
        transition: opacity 0.15s ease;
    }

    .stat-tooltip:hover::after,
    .stat-tooltip:hover::before {
        opacity: 1;
        transform: translateY(0);
    }

    /* Wrapper enables horizontal scrolling for lots of columns */
    .grid-wrap {
        width: 200%;
        overflow-x: auto;
    }

    /* Prevent the grid from trying to fit all columns into the viewport */
    .player-stats-grid .rz-datatable {
        table-layout: auto;
    }

    /* Critical: stop character-by-character wrapping */
    .player-stats-grid .rz-cell,
    .player-stats-grid .rz-column-title,
    .player-stats-grid th,
    .player-stats-grid td {
        white-space: nowrap;
    }

    /* Optional: keep headers readable */
    .player-stats-grid th {
        position: sticky;
        top: 0;
        z-index: 2;
        background: white;
    }

    .stat-header {
        cursor: help;
        border-bottom: 1px dotted rgba(0,0,0,0.4);
        white-space: nowrap;
    }
</style>
