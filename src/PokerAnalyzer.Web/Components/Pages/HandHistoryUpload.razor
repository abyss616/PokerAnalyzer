@page "/handhistories/upload"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components.Web
@using PokerAnalyzer.Web.Models
@inject PokerAnalyzer.Web.Services.ApiClient Api
@inject TooltipService TooltipService
<h3>Upload Hand History (XML)</h3>

<p>Select an XML hand history file. Upload starts immediately.</p>

<InputFile OnChange="OnFileSelected" accept=".xml" />

@if (_traceLines.Count > 0)
{
    <div class="alert alert-secondary mt-3">
        <strong>Trace</strong>
        <pre style="white-space:pre-wrap; margin-bottom: 0;">@string.Join("\n", _traceLines)</pre>
    </div>
}

@if (!string.IsNullOrWhiteSpace(_status))
{
    <div class="alert alert-info mt-3">
        @_status
    </div>
}

@if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger mt-3">
        <pre style="white-space:pre-wrap">@_error</pre>
    </div>
}


<div class="mt-4 card p-3">
    <h4>Preflop Analysis By Hand Number</h4>
    <div class="d-flex gap-2 align-items-center">
        <input class="form-control" style="max-width: 260px" @bind="_analysisHandNumberInput" placeholder="Enter hand number" />
        <button class="btn btn-primary" @onclick="AnalyzePreflopByHandNumberAsync" disabled="@_isAnalyzing">Analyze</button>
        <span class="text-muted">Timer: @_analysisElapsedDisplay</span>
    </div>

    @if (!string.IsNullOrWhiteSpace(_analysisError))
    {
        <div class="alert alert-danger mt-3">@_analysisError</div>
    }

    @if (_preflopAnalysis is not null)
    {
        <div class="mt-3">
            <div><strong>Support status:</strong> @(_preflopAnalysis.IsSupported ? "Supported" : "Unsupported")</div>
            @if (!_preflopAnalysis.IsSupported && !string.IsNullOrWhiteSpace(_preflopAnalysis.UnsupportedReason))
            {
                <div><strong>Unsupported reason:</strong> @_preflopAnalysis.UnsupportedReason</div>
            }
            <div><strong>Canonical preflop solver node:</strong> @_preflopAnalysis.CanonicalKey</div>
            <div><strong>Solver key:</strong> @_preflopAnalysis.SolverKey</div>
            <div><strong>Spot:</strong> @_preflopAnalysis.Street | @_preflopAnalysis.ActingPosition vs @_preflopAnalysis.FacingPosition</div>
            <div><strong>History:</strong> @_preflopAnalysis.HistorySignature</div>
            <div><strong>Pot / ToCall / Effective:</strong> @_preflopAnalysis.PotBb bb / @_preflopAnalysis.ToCallBb bb / @_preflopAnalysis.EffectiveStackBb bb</div>
            <div><strong>Raise depth:</strong> @_preflopAnalysis.RaiseDepth</div>
            <div><strong>Sizing buckets:</strong> @_preflopAnalysis.SizingBucketSummary</div>
            <div><strong>Strategy source:</strong> @_preflopAnalysis.SolveMetadata.StrategySource</div>
            <div><strong>Solve mode:</strong> @_preflopAnalysis.SolveMetadata.SolveMode</div>
            <div><strong>Hero hand:</strong> @(_preflopAnalysis.HeroHand ?? _preflopAnalysis.SolveMetadata.HeroHand ?? _preflopAnalysis.SolveMetadata.LeafEvaluationDetails?.HeroHand ?? "n/a")</div>
            <div class="text-muted small mt-1">Level-2 values are driven by hero hole cards, node family, positions/heads-up context, weighted opponent range, and computed equity. Similar frequencies do not necessarily mean hands are strategically identical.</div>
            <div><strong>Iterations:</strong> @_preflopAnalysis.SolveMetadata.IterationsCompleted</div>
            <div><strong>Elapsed:</strong> @_preflopAnalysis.SolveMetadata.ElapsedMilliseconds ms</div>


            @if (_preflopAnalysis.SolveMetadata.LeafEvaluationDetails is not null)
            {
                var leaf = _preflopAnalysis.SolveMetadata.LeafEvaluationDetails;
                <div class="card mt-3 border-info">
                    <div class="card-body">
                        <div class="d-flex align-items-center justify-content-between">
                            <strong>Why this hand got this strategy</strong>
                            <span class="badge bg-info text-dark">@leaf.EvaluatorType</span>
                        </div>

                        @if (leaf.UsedFallbackEvaluator)
                        {
                            <div class="alert alert-warning mt-2 mb-2">
                                Fallback evaluator used.
                                @if (!string.IsNullOrWhiteSpace(leaf.FallbackReason))
                                {
                                    <span> Reason: @leaf.FallbackReason</span>
                                }
                            </div>
                        }
                        else if (leaf.UsedEquityEvaluator)
                        {
                            <div class="alert alert-success mt-2 mb-2">
                                Equity-based leaf utility computed from weighted opponent range.
                            </div>
                        }

                        <table class="table table-sm mb-0">
                            <tbody>
                                <tr><th>Hero hand</th><td>@leaf.HeroHand</td><th>Hand class</th><td>@leaf.HandClass</td></tr>
                                <tr><th>Hero position</th><td>@leaf.HeroPosition</td><th>Villain position</th><td>@leaf.VillainPosition</td></tr>
                                <tr><th>Node family</th><td>@leaf.NodeFamily</td><th>Heads-up</th><td>@(leaf.IsHeadsUp ? "Yes" : "No")</td></tr>
                                <tr><th>Abstraction</th><td>@leaf.AbstractionSource</td><th>Synthetic defender</th><td>@leaf.SyntheticDefenderLabel</td></tr>
                                <tr><th>Actual opponents</th><td>@leaf.ActualActiveOpponentCount</td><th>Abstracted opponents</th><td>@leaf.AbstractedOpponentCount</td></tr>
                                <tr><th>Range description</th><td>@leaf.RangeDescription</td><th>Range detail</th><td>@leaf.RangeDetail</td></tr>
                                <tr><th>Filtered combos</th><td>@leaf.FilteredCombos</td><th>Hero equity</th><td>@(leaf.HeroEquity?.ToString("0.000") ?? "n/a")</td></tr>
                                <tr><th>Fold probability</th><td>@(leaf.FoldProbability?.ToString("0.000") ?? "n/a")</td><th>Continue probability</th><td>@(leaf.ContinueProbability?.ToString("0.000") ?? "n/a")</td></tr>
                                <tr><th>Root action</th><td>@(leaf.RootActionType ?? "n/a")</td><th>Immediate win component</th><td>@(leaf.ImmediateWinComponent?.ToString("0.000") ?? "n/a")</td></tr>
                                <tr><th>Continue component</th><td>@(leaf.ContinueComponent?.ToString("0.000") ?? "n/a")</td><th>Continue branch utility</th><td>@(leaf.ContinueBranchUtility?.ToString("0.000") ?? "n/a")</td></tr>
                                <tr><th>Hero utility</th><td>@(leaf.HeroUtility?.ToString("0.000") ?? "n/a")</td><th>Fallback reason</th><td>@leaf.FallbackReason</td></tr>
                                <tr><th>Equity percentile</th><td>@(leaf.EquityVsRangePercentile?.ToString("P0") ?? "n/a")</td><th>Blockers</th><td>@leaf.BlockerSummary</td></tr>
                            </tbody>
                        </table>
                        @if (!string.IsNullOrWhiteSpace(leaf.DisplaySummary))
                        {
                            <div class="text-muted small mt-2">@leaf.DisplaySummary</div>
                        }
                        @if (!string.IsNullOrWhiteSpace(leaf.RationaleSummary))
                        {
                            <div class="text-muted small mt-1">@leaf.RationaleSummary</div>
                        }
                    </div>
                </div>
            }

            @if (_preflopAnalysis.ActionDiagnostics.Count > 0)
            {
                <div class="card mt-3 border-secondary">
                    <div class="card-body">
                        <strong>Action diagnostics</strong>
                        <div class="text-muted small">@_preflopAnalysis.ActionValueSupport</div>
                        <div class="small">Best action margin: @(_preflopAnalysis.BestActionMargin?.ToString("0.##") ?? "n/a")%</div>
                        <div class="small">Separation score: @(_preflopAnalysis.SeparationScore?.ToString("0.####") ?? "n/a")</div>
                        <table class="table table-sm mb-0 mt-2">
                            <thead><tr><th>Action</th><th class="text-end">Freq</th><th class="text-end">Regret</th></tr></thead>
                            <tbody>
                                @foreach (var d in _preflopAnalysis.ActionDiagnostics)
                                {
                                    <tr><td>@d.ActionKey</td><td class="text-end">@d.Frequency.ToString("0.##")%</td><td class="text-end">@d.Regret.ToString("0.000")</td></tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }

            <div class="row mt-2 g-3">
                <div class="col-md-6">
                    <div class="card h-100">
                        <div class="card-body">
                            <div><strong>Legal actions</strong></div>
                            <ul class="mb-0">
                                @foreach (var action in _preflopAnalysis.LegalActions)
                                {
                                    <li>@action.ActionKey (@action.ActionType@(action.SizeBb.HasValue ? $", {action.SizeBb:0.##}bb" : ""))</li>
                                }
                            </ul>
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="card h-100">
                        <div class="card-body">
                            <div class="d-flex align-items-center gap-2">
                                <strong>Solver recommendation</strong>
                                @if (!string.IsNullOrWhiteSpace(_preflopAnalysis.StrategyStatus))
                                {
                                    <span class="badge @GetStrategyBadgeClass(_preflopAnalysis.StrategyStatus)">@_preflopAnalysis.StrategyStatus</span>
                                }
                            </div>

                            @if (!_preflopAnalysis.HasStrategy)
                            {
                                <div class="alert alert-warning mt-2 mb-2">No solved strategy available for this node.</div>
                                @if (!string.IsNullOrWhiteSpace(_preflopAnalysis.StrategyExplanation))
                                {
                                    <div class="text-muted">@_preflopAnalysis.StrategyExplanation</div>
                                }
                            }
                            else
                            {
                                @if (!string.IsNullOrWhiteSpace(_preflopAnalysis.SummaryRecommendation))
                                {
                                    <div class="mt-2"><strong>@_preflopAnalysis.SummaryRecommendation</strong></div>
                                }

                                @if (_preflopAnalysis.IsFallbackStrategy || _preflopAnalysis.IsUniformStrategy)
                                {
                                    @if (!string.IsNullOrWhiteSpace(_preflopAnalysis.StrategyExplanation))
                                    {
                                        <div class="text-muted mt-1">@_preflopAnalysis.StrategyExplanation</div>
                                    }
                                }

                                @if (_preflopAnalysis.Recommendations.Count > 0)
                                {
                                    <table class="table table-sm mb-0 mt-2 @(_preflopAnalysis.IsFallbackStrategy || _preflopAnalysis.IsUniformStrategy ? "table-warning" : string.Empty)">
                                        <thead>
                                            <tr>
                                                <th>Action</th>
                                                <th class="text-end">Frequency</th>
                                                <th>Best</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var recommendation in _preflopAnalysis.Recommendations)
                                            {
                                                <tr>
                                                    <td>@recommendation.DisplayLabel</td>
                                                    <td class="text-end">@recommendation.Frequency.ToString("0.##")%</td>
                                                    <td>@(recommendation.IsBestAction ? "Best" : "")</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                }
                            }
                        </div>
                    </div>
                </div>
            </div>

            <details class="mt-2">
                <summary><strong>Mapping trace</strong></summary>
                <div>history=@_preflopAnalysis.Trace.HistorySignature, toCall=@_preflopAnalysis.Trace.ToCallBb, currentBet=@_preflopAnalysis.Trace.CurrentBetBb, pot=@_preflopAnalysis.Trace.PotBb</div>
                <ul>
                    @foreach (var raw in _preflopAnalysis.Trace.RawActionHistory)
                    {
                        <li>@raw.Position @raw.ActionType @raw.AmountBb bb</li>
                    }
                </ul>
            </details>
        </div>
    }
</div>

@if (_playerStats.Count > 0)
{
    <div class="mt-4">
        <h4>Player Stats</h4>

        <div class="grid-wrap">
            <RadzenDataGrid Data="@_playerStats"
                            TItem="PokerStatsGridModel"
                            AllowSorting="true"
                            AllowPaging="true"
                            PageSize="10"
                            AllowFiltering="true"
                            FilterMode="FilterMode.Simple"
                            AllowColumnResize="true"
                            ColumnResizeMode="DataGridColumnResizeMode.NextColumn"
                            AllowColumnReorder="true"
                            AllowColumnPicking="true"
                            Style="width: 100%;"
                            Class="player-stats-grid">

                <Columns>
                    <!-- Freeze these so you always see who/what row you're on -->
                    <RadzenDataGridColumn TItem="PokerStatsGridModel"
                                          Property="Player"
                                          Title="Player"
                                          Frozen="true"
                                          Width="220px" />

                    <RadzenDataGridColumn TItem="PokerStatsGridModel"
                                          Property="Hands"
                                          Title="Hands"
                                          Frozen="true"
                                          Width="100px"
                                          TextAlign="TextAlign.Right" />

                    @foreach (var statColumn in StatColumns)
                    {
                        <RadzenDataGridColumn TItem="PokerStatsGridModel"
                                              Property="@statColumn.Property"
                                              Title="@statColumn.Title"
                                              Width="100px"
                                              TextAlign="TextAlign.Right"
                                              Filterable="false"
                                              FormatString="{0:0.##}%">
                        </RadzenDataGridColumn>
                    }
                </Columns>
            </RadzenDataGrid>
        </div>
    </div>
}

@code {
    private string? _status;
    private string? _error;
    private string _analysisHandNumberInput = string.Empty;
    private string? _analysisError;
    private bool _isAnalyzing;
    private TimeSpan _analysisElapsed = TimeSpan.Zero;
    private string _analysisElapsedDisplay = "00:00.000";
    private CancellationTokenSource? _analysisTimerCts;
    private PokerAnalyzer.Web.Services.ApiClient.PreflopHandAnalysisResult? _preflopAnalysis;
    private readonly List<string> _traceLines = new();
    private IReadOnlyList<PokerStatsGridModel> _playerStats = Array.Empty<PokerStatsGridModel>();
    private static readonly IReadOnlyList<StatColumn> StatColumns = new[]
    {
        new StatColumn("VPIP", nameof(PokerStatsGridModel.VPIP)),
        new StatColumn("PFR", nameof(PokerStatsGridModel.PFR)),
        new StatColumn("3Bet", nameof(PokerStatsGridModel.ThreeBet)),
        new StatColumn("Faced 3Bet", nameof(PokerStatsGridModel.Faced3Bet)),
        new StatColumn("Fold to 3Bet", nameof(PokerStatsGridModel.FoldTo3Bet)),
        new StatColumn("Flop WTSD", nameof(PokerStatsGridModel.FlopWTSD)),
        new StatColumn("Flop W$SD", nameof(PokerStatsGridModel.FlopWSD)),
        new StatColumn("Flop CBet Opp", nameof(PokerStatsGridModel.FlopCBetOpp)),
        new StatColumn("Flop CBet", nameof(PokerStatsGridModel.FlopCBet)),
        new StatColumn("Fold to Flop CBet Opp", nameof(PokerStatsGridModel.FoldToFlopCBetOpp)),
        new StatColumn("Fold to Flop CBet", nameof(PokerStatsGridModel.FoldToFlopCBet)),
        new StatColumn("First Fold to CBet", nameof(PokerStatsGridModel.FirstFoldToCBet)),
        new StatColumn("Call vs CBet", nameof(PokerStatsGridModel.CallVsCBet)),
        new StatColumn("Raise vs CBet", nameof(PokerStatsGridModel.RaiseVsCBet)),
        new StatColumn("Multiway CBet", nameof(PokerStatsGridModel.MultiwayCBet)),
        new StatColumn("Turn WTSD", nameof(PokerStatsGridModel.TurnWTSD)),
        new StatColumn("Turn W$SD", nameof(PokerStatsGridModel.TurnWSD)),
        new StatColumn("Turn CBet", nameof(PokerStatsGridModel.TurnCBet)),
        new StatColumn("Turn Fold to Bet", nameof(PokerStatsGridModel.TurnFoldToBet)),
        new StatColumn("Turn Aggression", nameof(PokerStatsGridModel.TurnAggression)),
        new StatColumn("Turn WTSD Carryover", nameof(PokerStatsGridModel.TurnWTSDCarryover)),
        new StatColumn("River WTSD", nameof(PokerStatsGridModel.RiverWTSD)),
        new StatColumn("River W$SD", nameof(PokerStatsGridModel.RiverWSD)),
        new StatColumn("River Bets When Checked To", nameof(PokerStatsGridModel.RiverBetsWhenCheckedTo)),
        new StatColumn("River Fold to Bet", nameof(PokerStatsGridModel.RiverFoldToBet)),
        new StatColumn("River Aggression", nameof(PokerStatsGridModel.RiverAggression))
    };
    private static readonly IReadOnlyDictionary<string, string> StatDescriptions = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
    {
        ["VPIP"] = "Voluntarily Put Money In Pot: % of hands where the player called or raised preflop.",
        ["PFR"] = "Preflop Raise: % of hands where the player raised preflop.",
        ["3Bet"] = "Three-bet: % of hands where the player re-raised preflop.",
        ["Faced 3Bet"] = "Faced a three-bet: % of hands where the player opened and faced a re-raise.",
        ["Fold to 3Bet"] = "Folded to a three-bet after opening preflop.",
        ["Flop WTSD"] = "Flop Went To Showdown: % of hands reaching showdown after seeing the flop.",
        ["Flop W$SD"] = "Flop Won at Showdown: % of showdowns won after seeing the flop.",
        ["Flop CBet Opp"] = "Flop continuation bet opportunities: % of hands where the preflop aggressor could c-bet on the flop.",
        ["Flop CBet"] = "Flop continuation bet: % of opportunities where the player c-bet the flop.",
        ["Fold to Flop CBet Opp"] = "Flop fold-to-c-bet opportunities: % of hands where the player faced a flop c-bet.",
        ["Fold to Flop CBet"] = "Flop fold to c-bet: % of times the player folded when facing a flop c-bet.",
        ["First Fold to CBet"] = "First fold to flop c-bet: % of hands where the player was the first to fold versus a flop c-bet.",
        ["Call vs CBet"] = "Call vs flop c-bet: % of times the player called when facing a flop c-bet.",
        ["Raise vs CBet"] = "Raise vs flop c-bet: % of times the player raised when facing a flop c-bet.",
        ["Multiway CBet"] = "Multiway c-bet: % of times the player c-bet the flop in a multiway pot.",
        ["Turn WTSD"] = "Turn Went To Showdown: % of hands reaching showdown after seeing the turn.",
        ["Turn W$SD"] = "Turn Won at Showdown: % of showdowns won after seeing the turn.",
        ["Turn CBet"] = "Turn continuation bet: % of times the player fired a second barrel on the turn.",
        ["Turn Fold to Bet"] = "Turn fold to bet: % of times the player folded when facing a turn bet.",
        ["Turn Aggression"] = "Turn aggression factor: bets and raises divided by calls on the turn.",
        ["Turn WTSD Carryover"] = "Turn WTSD carryover: % of hands that reached showdown after seeing the turn.",
        ["River WTSD"] = "River Went To Showdown: % of hands reaching showdown after seeing the river.",
        ["River W$SD"] = "River Won at Showdown: % of showdowns won after seeing the river.",
        ["River Bets When Checked To"] = "River bet when checked to: % of times the player bet the river after it checked to them.",
        ["River Fold to Bet"] = "River fold to bet: % of times the player folded when facing a river bet.",
        ["River Aggression"] = "River aggression factor: bets and raises divided by calls on the river."
    };

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        _status = null;
        _error = null;
        _playerStats = Array.Empty<PokerStatsGridModel>();
        _traceLines.Clear();
        AddTrace("InputFile selection changed.");

        try
        {
            var file = e.File;
            if (file is null)
            {
                _error = "No file received from InputFile.";
                AddTrace("No file received from InputFile.");
                return;
            }

            _status = $"Selected: {file.Name} ({file.Size} bytes). Uploading...";
            AddTrace($"Selected file '{file.Name}' ({file.Size} bytes).");
            AddTrace("Uploading XML hand history to API.");

            var result = await Api.UploadHandHistoryXmlAsync(file);

            _status = $"Upload successful. SessionId: {result.SessionId}";
            AddTrace($"Upload succeeded. SessionId: {result.SessionId}");
            AddTrace("Fetching player stats for uploaded session.");

            var stats = await Api.GetPlayerStatsAsync(result.SessionId);
            _playerStats = stats.Select(MapToGridModel).ToList();
            AddTrace($"Received {_playerStats.Count} player stat rows.");
        }
        catch (Exception ex)
        {
            _error = ex.ToString();
            AddTrace($"Error: {ex.Message}");
        }
    }

    private async Task AnalyzePreflopByHandNumberAsync()
    {
        _analysisError = null;
        _preflopAnalysis = null;
        ResetAnalysisTimer();

        if (!long.TryParse(_analysisHandNumberInput, out var handNumber) || handNumber <= 0)
        {
            _analysisError = "Please enter a valid positive hand number.";
            return;
        }

        _isAnalyzing = true;
        _analysisTimerCts = new CancellationTokenSource();
        var startedAt = DateTime.UtcNow;
        _ = RunAnalysisTimerAsync(startedAt, _analysisTimerCts.Token);

        try
        {
            _preflopAnalysis = await Api.AnalyzePreflopByHandNumberAsync(handNumber);
            if (_preflopAnalysis is null)
                _analysisError = "Hand number not found.";
        }
        catch (Exception ex)
        {
            _analysisError = ex.Message;
        }
        finally
        {
            _analysisTimerCts?.Cancel();
            _analysisTimerCts?.Dispose();
            _analysisTimerCts = null;
            _analysisElapsed = DateTime.UtcNow - startedAt;
            _analysisElapsedDisplay = FormatElapsed(_analysisElapsed);
            _isAnalyzing = false;
        }
    }

    private void ResetAnalysisTimer()
    {
        _analysisTimerCts?.Cancel();
        _analysisTimerCts?.Dispose();
        _analysisTimerCts = null;
        _analysisElapsed = TimeSpan.Zero;
        _analysisElapsedDisplay = FormatElapsed(_analysisElapsed);
        _isAnalyzing = false;
    }

    private async Task RunAnalysisTimerAsync(DateTime startedAt, CancellationToken cancellationToken)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromMilliseconds(100));
        try
        {
            while (await timer.WaitForNextTickAsync(cancellationToken))
            {
                _analysisElapsed = DateTime.UtcNow - startedAt;
                _analysisElapsedDisplay = FormatElapsed(_analysisElapsed);
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException)
        {
            // Timer cancelled intentionally.
        }
    }

    private static string FormatElapsed(TimeSpan elapsed)
        => $"{(int)elapsed.TotalMinutes:00}:{elapsed.Seconds:00}.{elapsed.Milliseconds:000}";


    private static string GetStrategyBadgeClass(string? status)
        => status?.ToLowerInvariant() switch
        {
            "solved" => "bg-success",
            "fallback" => "bg-warning text-dark",
            "uniform" => "bg-info text-dark",
            "untrained" => "bg-info text-dark",
            "unsupported" => "bg-secondary",
            "nostrategy" => "bg-secondary",
            _ => "bg-light text-dark"
        };

    private void AddTrace(string message)
        => _traceLines.Add($"[{DateTime.Now:HH:mm:ss}] {message}");

    private static string GetStatDescription(string statName) =>
        StatDescriptions.TryGetValue(statName, out var description)
            ? description
            : "No description available.";

    private static PokerStatsGridModel MapToGridModel(PokerAnalyzer.Web.Services.ApiClient.PlayerStatsResult player)
    {
        var stats = player.Stats.ToDictionary(stat => stat.Name, StringComparer.OrdinalIgnoreCase);
        decimal? GetValue(string name) =>
            stats.TryGetValue(name, out var stat) ? stat.Percent : null;

        return new PokerStatsGridModel
        {
            Player = player.Player,
            Hands = player.Hands,
            VPIP = GetValue("VPIP"),
            PFR = GetValue("PFR"),
            ThreeBet = GetValue("3Bet"),
            Faced3Bet = GetValue("Faced 3Bet"),
            FoldTo3Bet = GetValue("Fold to 3Bet"),
            FlopWTSD = GetValue("Flop WTSD"),
            FlopWSD = GetValue("Flop W$SD"),
            FlopCBetOpp = GetValue("Flop CBet Opp"),
            FlopCBet = GetValue("Flop CBet"),
            FoldToFlopCBetOpp = GetValue("Fold to Flop CBet Opp"),
            FoldToFlopCBet = GetValue("Fold to Flop CBet"),
            FirstFoldToCBet = GetValue("First Fold to CBet"),
            CallVsCBet = GetValue("Call vs CBet"),
            RaiseVsCBet = GetValue("Raise vs CBet"),
            MultiwayCBet = GetValue("Multiway CBet"),
            TurnWTSD = GetValue("Turn WTSD"),
            TurnWSD = GetValue("Turn W$SD"),
            TurnCBet = GetValue("Turn CBet"),
            TurnFoldToBet = GetValue("Turn Fold to Bet"),
            TurnAggression = GetValue("Turn Aggression"),
            TurnWTSDCarryover = GetValue("Turn WTSD Carryover"),
            RiverWTSD = GetValue("River WTSD"),
            RiverWSD = GetValue("River W$SD"),
            RiverBetsWhenCheckedTo = GetValue("River Bets When Checked To"),
            RiverFoldToBet = GetValue("River Fold to Bet"),
            RiverAggression = GetValue("River Aggression")
        };
    }

    private sealed record StatColumn(string Title, string Property);
}

<style>
    .stat-tooltip {
        position: relative;
        cursor: help;
        border-bottom: 1px dotted rgba(0, 0, 0, 0.35);
    }

    .stat-tooltip::after {
        content: attr(data-tooltip);
        position: absolute;
        left: 0;
        top: 125%;
        z-index: 10;
        min-width: 220px;
        max-width: 320px;
        padding: 0.35rem 0.5rem;
        border-radius: 0.35rem;
        background: rgba(33, 37, 41, 0.95);
        color: #fff;
        font-size: 0.75rem;
        line-height: 1.2;
        opacity: 0;
        pointer-events: none;
        transform: translateY(-4px);
        transition: opacity 0.15s ease, transform 0.15s ease;
        white-space: normal;
    }

    .stat-tooltip::before {
        content: "";
        position: absolute;
        left: 12px;
        top: 115%;
        border-width: 6px;
        border-style: solid;
        border-color: transparent transparent rgba(33, 37, 41, 0.95) transparent;
        opacity: 0;
        transition: opacity 0.15s ease;
    }

