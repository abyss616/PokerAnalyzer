@page "/leakage-stats"
@rendermode InteractiveServer
@using PokerAnalyzer.Web.Models

<h1>Leakage Stats</h1>

<p>Review key leakage indicators for each player.</p>

<RadzenDataGrid Data="@_leakageStats"
                TItem="LeakageStats"
                AllowSorting="true"
                AllowPaging="true"
                PageSize="10"
                AllowFiltering="true"
                FilterMode="FilterMode.Simple"
                AllowColumnResize="true"
                ColumnResizeMode="DataGridColumnResizeMode.NextColumn"
                AllowColumnReorder="true"
                AllowColumnPicking="true"
                Style="width: 100%;"
                Class="leakage-stats-grid">
    <Columns>
        <RadzenDataGridColumn TItem="LeakageStats"
                              Property="PlayerName"
                              Title="Player"
                              Frozen="true"
                              Width="220px" />
        <RadzenDataGridColumn TItem="LeakageStats"
                              Property="FoldBbVsSteal"
                              Title="Fold BB vs Steal"
                              Width="140px"
                              TextAlign="TextAlign.Right"
                              FormatString="{0:0.##}%" />
    </Columns>
</RadzenDataGrid>

@if (_leakageStats.Count == 0)
{
    <p class="mt-3 text-muted">No leakage stats loaded yet.</p>
}

@code {
    private IReadOnlyList<LeakageStats> _leakageStats = Array.Empty<LeakageStats>();
}
