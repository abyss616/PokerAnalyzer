@page "/leakage-stats"
@rendermode InteractiveServer
@using PokerAnalyzer.Infrastructure.Persistence
@using PokerAnalyzer.Web.Models
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<PokerDbContext> DbFactory

<h3>Leakage Stats</h3>

<p>Leakage stats load automatically from the latest uploaded session.</p>

@if (!string.IsNullOrWhiteSpace(_status))
{
    <div class="alert alert-info mt-3">
        @_status
    </div>
}

@if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger mt-3">
        <pre style="white-space:pre-wrap">@_error</pre>
    </div>
}

@if (_leakageStats.Count > 0)
{
    <div class="mt-4">
        <h4>Leakage Stats</h4>

        <div class="grid-wrap">
            <RadzenDataGrid Data="@_leakageStats"
                            TItem="LeakageStatsGridModel"
                            AllowSorting="true"
                            AllowPaging="true"
                            PageSize="10"
                            AllowFiltering="true"
                            FilterMode="FilterMode.Simple"
                            AllowColumnResize="true"
                            ColumnResizeMode="DataGridColumnResizeMode.NextColumn"
                            AllowColumnReorder="true"
                            AllowColumnPicking="true"
                            Style="width: 100%;"
                            Class="player-stats-grid">
                <Columns>
                    <RadzenDataGridColumn TItem="LeakageStatsGridModel"
                                          Property="PlayerName"
                                          Title="Player"
                                          Frozen="true"
                                          Width="220px" />
                    <RadzenDataGridColumn TItem="LeakageStatsGridModel"
                                          Property="FoldBBvsSteal"
                                          Title="Fold BB vs Steal"
                                          Width="160px"
                                          TextAlign="TextAlign.Right"
                                          Filterable="false"
                                          FormatString="{0:0.##}%">
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="LeakageStatsGridModel"
                                          Property="RfiButton"
                                          Title="RFI BTN"
                                          Width="140px"
                                          TextAlign="TextAlign.Right"
                                          Filterable="false"
                                          FormatString="{0:0.##}%">
                    </RadzenDataGridColumn>
                </Columns>
            </RadzenDataGrid>
        </div>
    </div>
}

@code {
    private string? _status;
    private string? _error;
    private IReadOnlyList<LeakageStatsGridModel> _leakageStats = Array.Empty<LeakageStatsGridModel>();

    protected override async Task OnInitializedAsync()
    {
        _status = "Loading leakage stats...";
        _error = null;
        _leakageStats = Array.Empty<LeakageStatsGridModel>();

        try
        {

            await using var db = await DbFactory.CreateDbContextAsync();
            var latestSessionId = await db.Sessions
                .AsNoTracking()
                .OrderByDescending(s => s.UploadedAtUtc)
                .Select(s => s.Id)
                .FirstOrDefaultAsync();

            if (latestSessionId == Guid.Empty)
            {
                _status = "No leakage stats found for the latest session.";
                return;
            }
       
            var players = await db.PlayerProfiles
                .AsNoTracking()
                .Where(p => p.SessionId == latestSessionId)
                .OrderBy(p => p.Player)
                .ToListAsync();

            _leakageStats = players.Select(MapToLeakageGridModel).ToList();
            _status = _leakageStats.Count > 0 ? null : "No leakage stats found for the latest session.";
        }
        catch (Exception ex)
        {
            _error = ex.ToString();
            _status = null;
        }
    }

    private static LeakageStatsGridModel MapToLeakageGridModel(PlayerProfile player)
    {
        var bb = player.PreflopModel.Positions.Bb;
        var foldBBvsSteal = bb.FacedLateOpenHands <= 0
            ? 0m
            : Math.Round((decimal)bb.FoldedVsLateOpenHands / bb.FacedLateOpenHands * 100m, 2);

        return new LeakageStatsGridModel
        {
            PlayerName = player.Player,
            FoldBBvsSteal = GetValue(bb)
        };
    }

    private static decimal GetFoldBbVsStealValue(PositionPreflopStats bb)
        => bb.FacedLateOpenHands <= 0
            ? 0m
            : Math.Round((decimal)bb.FoldedVsLateOpenHands / bb.FacedLateOpenHands * 100m, 2);

    private static decimal GetRfiButtonValue(PositionPreflopStats btn)
        => btn.FirstInHands <= 0
            ? 0m
            : Math.Round((decimal)btn.RaisedFirstInHands / btn.FirstInHands * 100m, 2);
}

<style>
    /* Normal responsive wrapper: only scroll if it truly overflows */
    .grid-wrap {
        width: 100%;
        overflow-x: auto;
    }

    /* Let the grid take full width */
    .player-stats-grid {
        width: 100%;
    }

        /* Optional: keep text readable but not force weird layout */
        .player-stats-grid .rz-cell,
        .player-stats-grid .rz-column-title,
        .player-stats-grid th,
        .player-stats-grid td {
            white-space: nowrap;
        }
</style>
